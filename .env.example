# ResearchCollab Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env, .env.local, production secrets, service-role keys, payment secrets, cookies, or private tokens.

# ─── Required Supabase browser-safe variables ───────────────────────
# Use the production project values in the deployment provider dashboard.
# These values are used by the Vite frontend, so they must be publishable/browser-safe only.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Optional metadata only. Do not use this as a secret.
VITE_SUPABASE_PROJECT_ID=your-project-id

# ─── App config ─────────────────────────────────────────────────────
# development | staging | production
VITE_APP_ENV=development
VITE_APP_VERSION=0.1.0
VITE_APP_NAME=ResearchCollab

# ─── Optional public payment config ─────────────────────────────────
# Use only publishable frontend keys here. Never add secret keys, webhook secrets,
# JazzCash/EasyPaisa credentials, bank credentials, or payout secrets to Vite env vars.
# Leave blank until real payment provider integration and audit flow are approved.
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Deployment checklist reminders ─────────────────────────────────
# Before production deploy:
# 1. Run npm ci
# 2. Run npm run lint
# 3. Run npm run build
# 4. Review GitHub Actions Build Check
# 5. Confirm Supabase redirect URLs match the production domain
# 6. Confirm demo-only funding/payment/payout actions remain locked
